# Required credentials
TRAKT_CLIENT_ID=your_trakt_client_id
TMDB_BEARER_TOKEN=your_tmdb_bearer_token

# Optional default username used by server tools
TRAKT_USERNAME=your_trakt_username

# Bearer token for MCP server authentication
# When set, all HTTP transport requests (streamable-http, sse) require:
#   Authorization: Bearer <MCP_BEARER_TOKEN>
# MCP_BEARER_TOKEN=your_mcp_bearer_token

# Test input overrides
TEST_TRAKT_USERNAME=your_trakt_username